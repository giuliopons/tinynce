# Copia questo file in deploy.env e compila le credenziali.
# deploy.env è gitignored — non committarlo mai.

DEPLOY_HOST=188.219.205.45
DEPLOY_PORT=21
DEPLOY_USER=USERNAME
DEPLOY_PASS=PASSWORD
DEPLOY_PATH=/opt/splunk

# Protocollo: ftp | ftps | sftp
# ftp   = FTP classico (porta 21)
# ftps  = FTP con TLS esplicito (porta 21, consigliato per Aruba)
# sftp  = SSH File Transfer (porta 22)
DEPLOY_PROTOCOL=ftps
